opna(subset=['marks'])\n","\n","        # Calculate Q1 and Q3\n","        Q1 = df['marks'].quantile(0.25)\n","        Q3 = df['marks'].quantile(0.75)\n","        IQR = Q3 - Q1\n","\n","        # Filter out outliers\n","        df = df[(df['marks'] >= Q1 - 1.5 * IQR) &\n","                (df['marks'] <= Q3 + 1.5 * IQR)]\n","\n","        print(\"Outliers removed successfully!\")\n","\n","    else:\n","        print(\"Error: 'marks' column not found in dataset.\")\n","\n","except FileNotFoundError:\n","    print(\"Error: File not found. Please upload 'student_performance.csv'.\")\n","\n","except Exception as e:\n","    print(\"Error:\", e)"],"metadata":{"id":"JgcmVg0OZrLQ","executionInfo":{"status":"ok","timestamp":1776328060404,"user_tz":-330,"elapsed":49,"user":{"displayName":"","userId":""}},"outputId":"023912f7-9bbe-4762-c547-ba4e77866bd1","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Error: File not found. Please upload 'student_performance.csv'.\n"]}]},{"cell_type":"markdown","source":["**7.Data Filtering**\n","\n","The dataset is filtered to remove students with very low attendance, as such records may not reflect meaningful academic behavior."],"metadata":{"id":"RpoCQIrTZ4tV"}},{"cell_type":"code","source":["import pandas as pd\n","\n","try:\n","    # Load dataset\n","    df = pd.read_csv(\"student_performance.csv\", encoding='latin-1')\n","\n","    # Check if column exists\n","    if 'attendance' in df.columns:\n","\n","        # Convert to numeric safely\n","        df['attendance'] = pd.to_numeric(df['attendance'], errors='coerce')\n","\n","        # Remove missing values\n","        df = df.dropna(subset=['attendance'])\n","\n","        # Filter attendance >= 60\n","        df = df[df['attendance'] >= 60]\n","\n","        print(\"Filtering completed: attendance >= 60\")\n","\n","    else:\n","        print(\"Error: 'attendance' column not found in dataset.\")\n","\n","exce